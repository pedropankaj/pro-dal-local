generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id String @id @default(uuid())

  title    String
  content  String
  image    String
  authorId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
